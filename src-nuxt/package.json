{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -Rf nuxt_modules .node_modules .nuxt dist package-lock.json pnpm-lock.yaml yarn.lock",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "lint": "eslint . && oxlint .",
    "typecheck": "nuxi typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p ${STORYBOOK_PORT:-1421}",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/scripts": "^0.13.4",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxt/ui": "^4.6.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@unhead/vue": "^2.1.13",
    "better-sqlite3": "^12.9.0",
    "eslint": "^9.39.4",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint-config-prettier": "^10.1.8",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "storybook": "^10.3.5",
    "vitest": "^4.1.4"
  }
}
